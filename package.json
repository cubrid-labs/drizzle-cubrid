{
  "name": "drizzle-cubrid",
  "version": "0.2.0",
  "description": "Drizzle ORM dialect for CUBRID database",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage --reporter=verbose",
    "integration": "vitest run tests/integration.test.ts --reporter=verbose",
    "lint": "eslint src/ tests/",
    "format": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "cubrid",
    "database",
    "orm",
    "sql",
    "typescript"
  ],
  "author": "cubrid-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cubrid-labs/drizzle-cubrid.git"
  },
  "bugs": {
    "url": "https://github.com/cubrid-labs/drizzle-cubrid/issues"
  },
  "homepage": "https://github.com/cubrid-labs/drizzle-cubrid#readme",
  "peerDependencies": {
    "drizzle-orm": ">=0.38.0",
    "cubrid-client": ">=0.1.0"
  },
  "devDependencies": {
    "cubrid-client": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-orm": "^0.38.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
